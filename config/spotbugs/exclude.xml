<?xml version="1.0" encoding="UTF-8" ?>
<FindBugsFilter>
    <!-- SpotBugs incorrectly flags the static engine field modification as a bug.
         This is intentional for testability (fault injection). -->
    <Match>
        <Class name="io.mazewall.LinuxNative" />
        <Or>
            <Method name="setEngine" />
            <Method name="resetToDefault" />
            <Method name="setTransactionManager" />
            <Method name="resetTransactionManager" />
        </Or>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD" />
    </Match>
    <Match>
        <Class name="io.mazewall.Platform" />
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD" />
    </Match>
    <Match>
        <Class name="io.mazewall.RealPlatformProvider" />
        <Or>
            <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD" />
            <Bug pattern="MS_CANNOT_BE_FINAL" />
            <Bug pattern="MS_SHOULD_BE_FINAL" />
        </Or>
    </Match>
    <Match>
        <Class name="io.mazewall.PlatformDiagnosticsTest" />
    </Match>
    <Match>
        <Class name="~io\.mazewall\.enforcer\.supervisor\.SupervisorSessionHandler.*" />
        <Bug pattern="DE_MIGHT_IGNORE" />
    </Match>
</FindBugsFilter>
