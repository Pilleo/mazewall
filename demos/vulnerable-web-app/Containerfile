FROM eclipse-temurin:25-jdk

WORKDIR /app

# Install dependencies (curl for health checks, strace for debugging)
RUN apt-get update && apt-get install -y curl strace && rm -rf /var/lib/apt/lists/*

# Copy the pre-built jar from the host
COPY build/libs/vulnerable-app.jar /app/vulnerable-app.jar

# Unpack the jar to support exploded classpath resolution for profiler daemon subprocesses
RUN mkdir -p /app/unpacked && cd /app/unpacked && jar -xf ../vulnerable-app.jar

# Expose ports
EXPOSE 8080

# Default command: run the exploded classpath
CMD ["java", "-cp", "/app/unpacked/BOOT-INF/classes:/app/unpacked/BOOT-INF/lib/*", "demo.vulnapp.VulnAppApplicationKt"]
